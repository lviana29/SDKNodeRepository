{
  "name": "@lviana29-solution/sdk-node-repository",
  "version": "1.0.4",
  "license": "MIT",
  "description": "An agnostic, type-safe Database Repository SDK built for Node.js applications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "commonjs",
  "files": [
    "dist"
  ],
  "scripts": {
