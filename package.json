    "demo": "ts-node --swc -r dotenv/config demo/main.ts"
  },
  "keywords": [],
  "author": "",
  "dependencies": {
    "sequelize": "^6.37.8",
    "sequelize-typescript": "^2.1.6"
  },
  "peerDependencies": {
    "@prisma/client": "^7.8.0"
  },
  "peerDependenciesMeta": {
    "@prisma/client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@swc/core": "^1.15.33",
    "@swc/helpers": "^0.5.21",
    "@types/node": "^20.19.41",
    "@types/validator": "^13.11.7",
    "cross-env": "^10.1.0",
    "mariadb": "^3.5.2",
    "mysql2": "^3.22.3",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
